#!/usr/bin/env bash
set -eo pipefail

MERGED_BRANCHES=""
GONE_BRANCHES=""

usage() {
  cat <<'EOF'
Usage: wt
       wt -
       wt --help
       wt --zsh-completion
       wt __list
       wt __path <branch>

With no arguments, wt opens an fzf picker when fzf is available.
Use "wt -" to resolve the repo root that owns .worktrees.

wt is normally used through its zsh autoload function so it can change the
current shell directory. The executable provides shared data for completion and
Neovim integrations.
EOF
}

find_worktrees_root() {
  local dir="${1:-$PWD}"
  local git_root

  while [ "$dir" != "/" ]; do
    if [ -d "$dir/.worktrees" ]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir=$(dirname "$dir")
  done

  git_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  if [ -n "$git_root" ]; then
    printf '%s\n' "$git_root"
    return 0
  fi

  return 1
}

default_branch_base() {
  local base
  base=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)
  if [ -n "$base" ]; then
    printf '%s\n' "$base"
    return 0
  fi

  if git show-ref --verify --quiet refs/heads/main; then
    printf '%s\n' main
    return 0
  fi

  if git show-ref --verify --quiet refs/heads/master; then
    printf '%s\n' master
    return 0
  fi

  return 1
}

list_contains() {
  local needle="$1"
  local haystack="$2"

  [ -n "$haystack" ] || return 1
  printf '%s\n' "$haystack" | grep -Fxq -- "$needle"
}

branch_label() {
  local branch="$1"
  local local_default_branch="$2"
  local label=""

  if list_contains "$branch" "$GONE_BRANCHES"; then
    label="gone"
  fi

  if [ "$branch" != "$local_default_branch" ] && list_contains "$branch" "$MERGED_BRANCHES"; then
    if [ -n "$label" ]; then
      label="$label, merged"
    else
      label="merged"
    fi
  fi

  printf '%s\n' "$label"
}

root_branch() {
  git branch --show-current 2>/dev/null || true
}

worktree_path_for_branch() {
  local target="$1"

  git worktree list --porcelain 2>/dev/null |
    awk -v target="$target" '
      function flush() {
        if (path != "" && branch == target) {
          print path
          found = 1
          exit
        }
        path = ""
        branch = ""
      }
      /^worktree / {
        flush()
        path = substr($0, 10)
        branch = ""
        next
      }
      /^branch refs\/heads\// {
        branch = substr($0, 19)
        next
      }
      /^$/ { flush() }
      END { if (!found) flush(); if (found) exit 0 }
    '
}

list_candidates() {
  local root root_branch_name default_branch local_default_branch branch path label label_field sort kind row seen_branches
  local -a worktree_rows branches normal_rows merged_rows gone_rows

  seen_branches=""

  root=$(find_worktrees_root) || {
    echo "Could not find .worktrees directory or Git repository root." >&2
    return 1
  }
  root=$(cd "$root" && pwd -P)

  cd "$root"
  root_branch_name=$(root_branch)

  if [ -n "$root_branch_name" ]; then
    printf '%s\t%s\t%s\t%s\t%s\n' "$root_branch_name" "$root" root root 0
    seen_branches="${seen_branches}${root_branch_name}"$'\n'
  fi

  while IFS= read -r row; do
    [ -n "$row" ] || continue
    worktree_rows+=("$row")
  done < <(
    git worktree list --porcelain 2>/dev/null |
      awk '
        function flush() {
          if (path != "" && branch != "") {
            marker = "/.worktrees/"
            idx = index(path, marker)
            if (idx > 0) print branch "\t" path
          }
          path = ""
          branch = ""
        }
        /^worktree / {
          flush()
          path = substr($0, 10)
          branch = ""
          next
        }
        /^branch refs\/heads\// {
          branch = substr($0, 19)
          next
        }
        /^$/ { flush() }
        END { flush() }
      '
  )

  while IFS= read -r branch; do
    [ -n "$branch" ] || continue
    branches+=("$branch")
  done < <(git for-each-ref --format='%(refname:short)' refs/heads/ 2>/dev/null)

  default_branch=$(default_branch_base || true)
  local_default_branch=${default_branch#*/}

  MERGED_BRANCHES=""
  if [ -n "$default_branch" ]; then
    while IFS= read -r branch; do
      [ -n "$branch" ] || continue
      MERGED_BRANCHES="${MERGED_BRANCHES}${branch}"$'\n'
    done < <(git for-each-ref --merged="$default_branch" --format='%(refname:short)' refs/heads/ 2>/dev/null)
  fi

  GONE_BRANCHES=""
  while IFS='|' read -r branch track; do
    [ -n "$branch" ] || continue
    if [ "$track" = "[gone]" ]; then
      GONE_BRANCHES="${GONE_BRANCHES}${branch}"$'\n'
    fi
  done < <(git for-each-ref --format='%(refname:short)|%(upstream:track)' refs/heads/ 2>/dev/null)

  for row in "${worktree_rows[@]}"; do
    [ -n "$row" ] || continue
    branch=${row%%$'\t'*}
    path=${row#*$'\t'}
    [ -n "$branch" ] || continue
    [ -n "$path" ] || continue
    list_contains "$branch" "$seen_branches" && continue
    seen_branches="${seen_branches}${branch}"$'\n'

    label="worktree"
    if list_contains "$branch" "$GONE_BRANCHES"; then
      label="$label, gone"
    fi
    if [ "$branch" != "$local_default_branch" ] && list_contains "$branch" "$MERGED_BRANCHES"; then
      label="$label, merged"
    fi

    printf '%s\t%s\t%s\t%s\t%s\n' "$branch" "$path" worktree "$label" 0
  done

  for branch in "${branches[@]}"; do
    [ -n "$branch" ] || continue
    list_contains "$branch" "$seen_branches" && continue
    seen_branches="${seen_branches}${branch}"$'\n'

    label=$(branch_label "$branch" "$local_default_branch")
    kind=""
    sort=1
    if [ -n "$label" ]; then
      if list_contains "$branch" "$GONE_BRANCHES"; then
        sort=3
      else
        sort=2
      fi
    fi

    path=""
    label_field="$label"
    row=$(printf '%s\t%s\t%s\t%s\t%s' "$branch" "$path" "$kind" "$label_field" "$sort")
    case "$sort" in
      2) merged_rows+=("$row") ;;
      3) gone_rows+=("$row") ;;
      *) normal_rows+=("$row") ;;
    esac
  done

  ((${#normal_rows[@]})) && printf '%s\n' "${normal_rows[@]}"
  ((${#merged_rows[@]})) && printf '%s\n' "${merged_rows[@]}"
  ((${#gone_rows[@]})) && printf '%s\n' "${gone_rows[@]}"
  return 0
}

resolve_path() {
  local target="${1:-}"
  local root worktree_dir worktree_parent path

  if [ -z "$target" ]; then
    echo "Usage: wt __path <branch>" >&2
    return 1
  fi

  root=$(find_worktrees_root) || {
    echo "Could not find .worktrees directory or Git repository root." >&2
    return 1
  }
  root=$(cd "$root" && pwd -P)

  cd "$root"

  if [ "$target" = "-" ]; then
    printf '%s\n' "$root"
    return 0
  fi

  worktree_dir="$root/.worktrees/$target"

  path=$(worktree_path_for_branch "$target")
  if [ -n "$path" ]; then
    printf '%s\n' "$path"
    return 0
  fi

  if [ -d "$worktree_dir" ]; then
    printf '%s\n' "$worktree_dir"
    return 0
  fi

  if git show-ref --verify --quiet "refs/heads/$target"; then
    echo "Creating worktree for branch '$target'..." >&2
    worktree_parent=$(dirname "$worktree_dir")
    mkdir -p "$worktree_parent"
    git worktree add "$worktree_dir" "$target" >&2
    printf '%s\n' "$worktree_dir"
    return 0
  fi

  echo "Branch '$target' does not exist" >&2
  return 1
}

format_rows() {
  awk -F '\t' '
    function display_label(label) {
      if (label ~ /(^|, )root($|,)/) return "[root]"
      if (label ~ /(^|, )merged($|,)/) return "[merged]"
      return ""
    }
    function display_path(path) {
      if (path == "") return ""
      if (root_path != "" && path == root_path) return "."
      if (root_path != "" && index(path, root_path "/") == 1) return substr(path, length(root_path) + 2)
      return path
    }
    {
      rows[NR] = $0
      if ($3 == "root") root_path = $2
      if (length($1) > w1) w1 = length($1)
    }
    END {
      for (i = 1; i <= NR; i++) {
        split(rows[i], f, "\t")
        shown_path[i] = display_path(f[2])
        if (length(shown_path[i]) > w2) w2 = length(shown_path[i])
      }
      for (i = 1; i <= NR; i++) {
        split(rows[i], f, "\t")
        label = display_label(f[4])
        if (shown_path[i] == "" && label != "") {
          printf "%-" w1 "s  %-" w2 "s  %s\n", f[1], "", label
        } else if (shown_path[i] == "") {
          print f[1]
        } else if (label != "") {
          printf "%-" w1 "s  %-" w2 "s  %s\n", f[1], shown_path[i], label
        } else {
          printf "%-" w1 "s  %s\n", f[1], shown_path[i]
        }
      }
    }
  '
}

pick_candidate() {
  local rows selection branch

  rows=$(list_candidates)
  if [ -z "$rows" ]; then
    echo "No worktrees or local branches found." >&2
    return 1
  fi

  if command -v fzf >/dev/null 2>&1; then
    selection=$(printf '%s\n' "$rows" | format_rows | fzf --height=~50%) || return 130
    branch=$(printf '%s\n' "$selection" | awk '{ print $1 }')
    [ -n "$branch" ] || return 1
    resolve_path "$branch"
  else
    printf '%s\n' "$rows" | format_rows
  fi
}

print_zsh_completion() {
  cat <<'EOF'
#compdef wt

_wt() {
  local -a values labels
  local -a active_values active_labels normal_values normal_labels merged_values merged_labels gone_values gone_labels
  local line branch worktree_path kind label sort formatted_label display_label display_path root_path cur
  local -a fields filtered_values filtered_labels
  local branch_width path_width max_branch_width=0 max_path_width=0 i

  _wt_fuzzy_match() {
    local needle="${1:l}" haystack="${2:l}" char
    local i

    [[ -n "$needle" ]] || return 0

    for ((i = 1; i <= ${#needle}; i++)); do
      char="${needle[i]}"
      if [[ "$haystack" == *"$char"* ]]; then
        haystack="${haystack#*"$char"}"
      else
        return 1
      fi
    done

    return 0
  }

  cur="${words[CURRENT]}"

  while IFS= read -r line; do
    fields=("${(@ps:\t:)line}")
    branch="$fields[1]"
    worktree_path="$fields[2]"
    kind="$fields[3]"
    [[ -n "$branch" ]] || continue
    [[ "$kind" == "root" ]] && root_path="$worktree_path"
  done < <(command wt __list 2>/dev/null)

  while IFS= read -r line; do
    fields=("${(@ps:\t:)line}")
    branch="$fields[1]"
    worktree_path="$fields[2]"
    [[ -n "$branch" ]] || continue
    display_path="$worktree_path"
    if [[ -n "$root_path" && "$worktree_path" == "$root_path" ]]; then
      display_path="."
    elif [[ -n "$root_path" && "$worktree_path" == "$root_path"/* ]]; then
      display_path="${worktree_path#$root_path/}"
    fi
    branch_width=${#branch}
    path_width=${#display_path}
    (( branch_width > max_branch_width )) && max_branch_width=$branch_width
    (( path_width > max_path_width )) && max_path_width=$path_width
  done < <(command wt __list 2>/dev/null)

  while IFS= read -r line; do
    fields=("${(@ps:\t:)line}")
    branch="$fields[1]"
    worktree_path="$fields[2]"
    kind="$fields[3]"
    label="$fields[4]"
    sort="$fields[5]"
    [[ -n "$branch" ]] || continue

    display_label=""
    if [[ "$label" == *root* ]]; then
      display_label="[root]"
    elif [[ "$label" == *merged* ]]; then
      display_label="[merged]"
    fi

    display_path="$worktree_path"
    if [[ -n "$root_path" && "$worktree_path" == "$root_path" ]]; then
      display_path="."
    elif [[ -n "$root_path" && "$worktree_path" == "$root_path"/* ]]; then
      display_path="${worktree_path#$root_path/}"
    fi

    if [[ -z "$display_path" && -n "$display_label" ]]; then
      formatted_label=$(printf "%-${max_branch_width}s  %-${max_path_width}s  %s" "$branch" "" "$display_label")
    elif [[ -z "$display_path" ]]; then
      formatted_label="$branch"
    elif [[ -n "$display_label" ]]; then
      formatted_label=$(printf "%-${max_branch_width}s  %-${max_path_width}s  %s" "$branch" "$display_path" "$display_label")
    else
      formatted_label=$(printf "%-${max_branch_width}s  %s" "$branch" "$display_path")
    fi

    case "$sort" in
      0)
        active_values+=("$branch")
        active_labels+=("$formatted_label")
        ;;
      2)
        merged_values+=("$branch")
        merged_labels+=("$formatted_label")
        ;;
      3)
        gone_values+=("$branch")
        gone_labels+=("$formatted_label")
        ;;
      *)
        normal_values+=("$branch")
        normal_labels+=("$formatted_label")
        ;;
    esac
  done < <(command wt __list 2>/dev/null)

  values=("${active_values[@]}" "${normal_values[@]}" "${merged_values[@]}" "${gone_values[@]}")
  labels=("${active_labels[@]}" "${normal_labels[@]}" "${merged_labels[@]}" "${gone_labels[@]}")

  if [[ -n "$cur" ]]; then
    for ((i = 1; i <= ${#values}; i++)); do
      if _wt_fuzzy_match "$cur" "${values[i]}"; then
        filtered_values+=("${values[i]}")
        filtered_labels+=("${labels[i]}")
      fi
    done

    (( ${#filtered_values} > 0 )) && compadd -U -Q -V wt-branches -d filtered_labels -l -- "${filtered_values[@]}"
  else
    (( ${#values} > 0 )) && compadd -Q -V wt-branches -d labels -l -- "${values[@]}"
  fi
}

compdef _wt wt
EOF
}

case "${1:-}" in
  --help|-h)
    usage
    ;;
  --zsh-completion)
    print_zsh_completion
    ;;
  __list)
    list_candidates
    ;;
  __path)
    shift
    resolve_path "${1:-}"
    ;;
  "")
    pick_candidate
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
