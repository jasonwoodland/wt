#!/usr/bin/env bash
set -eo pipefail

usage() {
  cat <<'EOF'
Usage: wt
       wt .
       wt -
       wt <branch>
       wt --latest
       wt -l
       wt --clean [-f] [--merged [<rev>]]
       wt -c [-f] [--merged [<rev>]]
       wt -cm
       wt -cfm
       wt --help
       wt --zsh-completion
       wt __list
       wt __path <target>

With no arguments, wt opens an fzf picker when fzf is available.
Use "wt ." to resolve the repo root that owns .worktrees.
Use "wt -" as a legacy alias for "wt .".
Use "wt <branch>" to resolve or create that branch's worktree path.
Use "wt --latest" or "wt -l" to resolve the latest local branch by committer date.
Use "wt --clean" or "wt -c" to remove clean non-main worktrees after confirmation.
Use "wt -c --merged [<rev>]" or "wt -cm" to remove only clean worktrees merged into <rev>.
When <rev> is omitted, --merged uses the root worktree HEAD.
Use "wt -cf" or "wt -cfm" to skip the confirmation prompt. -f never forces dirty worktree removal.

wt is normally used through its zsh autoload function so it can change the
current shell directory. The executable prints paths for shell, completion, and
Neovim integrations.
EOF
}

find_worktrees_root() {
  local start_dir="${1:-${WT_CWD:-$PWD}}"
  local dir="$start_dir"
  local git_root main_worktree

  while [ "$dir" != "/" ]; do
    if [ -d "$dir/.worktrees" ]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir=$(dirname "$dir")
  done

  main_worktree=$(git -C "$start_dir" worktree list --porcelain 2>/dev/null | awk '/^worktree / { print substr($0, 10); exit }' || true)
  if [ -n "$main_worktree" ]; then
    printf '%s\n' "$main_worktree"
    return 0
  fi

  git_root=$(git -C "$start_dir" rev-parse --show-toplevel 2>/dev/null || true)
  if [ -n "$git_root" ]; then
    printf '%s\n' "$git_root"
    return 0
  fi

  return 1
}

list_contains() {
  local needle="$1"
  local haystack="$2"

  [ -n "$haystack" ] || return 1
  printf '%s\n' "$haystack" | grep -Fxq -- "$needle"
}

root_branch() {
  git branch --show-current 2>/dev/null || true
}

is_existing_worktree_path() {
  local path="$1"

  [ -n "$path" ] || return 1
  [ -d "$path" ] || return 1
  git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

worktree_branch_rows() {
  git worktree list --porcelain 2>/dev/null |
    awk '
      function short_sha(value) {
        return substr(value, 1, 7)
      }
      function flush() {
        if (path != "" && branch != "") {
          print branch "\t" path "\t" short_sha(head)
        }
        path = ""
        branch = ""
        head = ""
      }
      /^worktree / {
        flush()
        path = substr($0, 10)
        branch = ""
        head = ""
        next
      }
      /^HEAD / {
        head = substr($0, 6)
        next
      }
      /^branch refs\/heads\// {
        branch = substr($0, 19)
        next
      }
      /^$/ { flush() }
      END { flush() }
    '
}

branch_ref_rows() {
  local sort_value
  local -a sort_args

  for sort_value in "$@"; do
    [ -n "$sort_value" ] || continue
    sort_args+=(--sort="$sort_value")
  done

  git for-each-ref "${sort_args[@]}" --format='%(refname:short)%09%(objectname:short=7)' refs/heads/ 2>/dev/null
}

latest_branch() {
  local root branch

  root=$(find_worktrees_root) || {
    echo "Could not find .worktrees directory or Git repository root." >&2
    return 1
  }
  root=$(cd "$root" && pwd -P)

  cd "$root"
  branch=$(git for-each-ref --sort=-committerdate --count=1 --format='%(refname:short)' refs/heads 2>/dev/null || true)
  if [ -z "$branch" ]; then
    echo "No local branches found." >&2
    return 1
  fi

  printf '%s\n' "$branch"
}

resolve_latest_path() {
  local branch

  branch=$(latest_branch) || return $?
  resolve_path "$branch"
}

latest_usage_error() {
  usage >&2
  return 2
}

is_latest_mixed_short_option_token() {
  local arg="${1:-}"

  case "$arg" in
    -|--*|-l)
      return 1
      ;;
    -*l*)
      return 0
      ;;
  esac

  return 1
}

worktree_path_for_branch() {
  local target="$1" branch path sha

  while IFS=$'\t' read -r branch path sha; do
    [ "$branch" = "$target" ] || continue
    is_existing_worktree_path "$path" || continue
    printf '%s\n' "$path"
    return 0
  done < <(worktree_branch_rows)

  return 0
}

worktree_rows() {
  git worktree list --porcelain 2>/dev/null |
    awk '
      function short_sha(value) {
        return substr(value, 1, 7)
      }
      function flush() {
        if (path != "") {
          print path "\t" branch "\t" short_sha(head)
        }
        path = ""
        branch = ""
        head = ""
      }
      /^worktree / {
        flush()
        path = substr($0, 10)
        branch = ""
        head = ""
        next
      }
      /^HEAD / {
        head = substr($0, 6)
        next
      }
      /^branch refs\/heads\// {
        branch = substr($0, 19)
        next
      }
      /^$/ { flush() }
      END { flush() }
    '
}

relative_path_for_root() {
  local path="$1" root="$2" rel=""
  local -a path_parts root_parts
  local i j

  if [ -z "$path" ]; then
    printf '\n'
    return 0
  fi
  if [ -n "$root" ] && [ "$path" = "$root" ]; then
    printf '.\n'
    return 0
  fi
  if [ -n "$root" ] && [ "$root" != "/" ] && [[ "$path" == "$root"/* ]]; then
    printf '%s\n' "${path#$root/}"
    return 0
  fi
  if [ "$root" = "/" ] && [[ "$path" == /* ]]; then
    printf '%s\n' "${path#/}"
    return 0
  fi
  if [ -n "$root" ] && [[ "$path" == /* ]] && [[ "$root" == /* ]]; then
    IFS=/ read -r -a path_parts <<< "$path"
    IFS=/ read -r -a root_parts <<< "$root"
    i=0
    while [ "$i" -lt "${#path_parts[@]}" ] && [ "$i" -lt "${#root_parts[@]}" ] && [ "${path_parts[$i]}" = "${root_parts[$i]}" ]; do
      i=$((i + 1))
    done
    for ((j = i; j < ${#root_parts[@]}; j++)); do
      [ -n "${root_parts[$j]}" ] && rel="${rel:+$rel/}.."
    done
    for ((j = i; j < ${#path_parts[@]}; j++)); do
      [ -n "${path_parts[$j]}" ] && rel="${rel:+$rel/}${path_parts[$j]}"
    done
    printf '%s\n' "${rel:-.}"
    return 0
  fi

  printf '%s\n' "$path"
}

worktree_is_clean() {
  local path="$1" status

  status=$(git -C "$path" status --porcelain --untracked-files=all 2>/dev/null || true)
  [ -z "$status" ]
}

clean_usage() {
  cat >&2 <<'EOF'
Usage: wt --clean [-f] [--merged [<rev>]]
       wt -c [-f] [--merged [<rev>]]
       wt -cm
       wt -cfm
EOF
}

is_clean_option_token() {
  local arg="${1:-}" flags

  case "$arg" in
    --clean|--merged|--merged=*)
      return 0
      ;;
    -)
      return 1
      ;;
    -*)
      flags=${arg#-}
      [ -n "$flags" ] || return 1
      case "$flags" in
        *[!cfm]*) return 1 ;;
        *) return 0 ;;
      esac
      ;;
  esac

  return 1
}

is_merged_rev_token() {
  local arg="${1:-}"

  [ -n "$arg" ] && [[ "$arg" != -* ]]
}

worktree_is_merged_to() {
  local path="$1" target_commit="$2" candidate_head

  candidate_head=$(git -C "$path" rev-parse --verify -q 'HEAD^{commit}' 2>/dev/null || true)
  [ -n "$candidate_head" ] || return 1
  git merge-base --is-ancestor "$candidate_head" "$target_commit" 2>/dev/null
}

print_clean_skips() {
  if [ "${#dirty_displays[@]}" -gt 0 ]; then
    echo "Skipped unclean worktrees:"
    printf '  %s\n' "${dirty_displays[@]}"
  fi
  if [ "${#unmerged_displays[@]}" -gt 0 ]; then
    echo "Skipped clean unmerged worktrees:"
    printf '  %s\n' "${unmerged_displays[@]}"
  fi
}

clean_worktrees() {
  local root no_confirm=0 clean_requested=0 merged_only=0 merged_rev="" merged_target merged_target_commit
  local arg flags ch reply path branch sha display failed=0 i
  local -a clean_paths clean_displays dirty_displays unmerged_displays failed_displays removed_displays

  while [ "$#" -gt 0 ]; do
    arg="$1"
    shift
    case "$arg" in
      --clean)
        clean_requested=1
        ;;
      --merged=*)
        merged_only=1
        if [ -n "$merged_rev" ]; then
          clean_usage
          return 2
        fi
        merged_rev=${arg#--merged=}
        if [ -z "$merged_rev" ]; then
          echo "Invalid --merged target: " >&2
          return 2
        fi
        ;;
      --merged)
        merged_only=1
        if [ "$#" -gt 0 ] && is_merged_rev_token "${1:-}"; then
          if [ -n "$merged_rev" ]; then
            clean_usage
            return 2
          fi
          merged_rev="$1"
          shift
        fi
        ;;
      -*)
        flags=${arg#-}
        [ -n "$flags" ] || {
          clean_usage
          return 2
        }
        case "$flags" in
          *[!cfm]*)
            clean_usage
            return 2
            ;;
        esac
        for ((i = 0; i < ${#flags}; i++)); do
          ch=${flags:i:1}
          case "$ch" in
            c) clean_requested=1 ;;
            f) no_confirm=1 ;;
            m) merged_only=1 ;;
          esac
        done
        if [ "$arg" = "-m" ] && [ "$#" -gt 0 ] && is_merged_rev_token "${1:-}"; then
          if [ -n "$merged_rev" ]; then
            clean_usage
            return 2
          fi
          merged_rev="$1"
          shift
        fi
        ;;
      *)
        clean_usage
        return 2
        ;;
    esac
  done

  if [ "$clean_requested" != 1 ]; then
    clean_usage
    return 2
  fi

  root=$(find_worktrees_root) || {
    echo "Could not find .worktrees directory or Git repository root." >&2
    return 1
  }
  root=$(cd "$root" && pwd -P)
  cd "$root"

  if [ "$merged_only" = 1 ]; then
    merged_target=${merged_rev:-HEAD}
    merged_target_commit=$(git rev-parse --verify -q "${merged_target}^{commit}" 2>/dev/null || true)
    if [ -z "$merged_target_commit" ]; then
      echo "Invalid --merged target: $merged_target" >&2
      return 2
    fi
  fi

  while IFS=$'\t' read -r path branch sha; do
    [ -n "$path" ] || continue
    [ "$path" != "$root" ] || continue
    is_existing_worktree_path "$path" || continue
    display=$(relative_path_for_root "$path" "$root")
    if ! worktree_is_clean "$path"; then
      dirty_displays+=("$display")
      continue
    fi
    if [ "$merged_only" = 1 ] && ! worktree_is_merged_to "$path" "$merged_target_commit"; then
      unmerged_displays+=("$display")
      continue
    fi
    clean_paths+=("$path")
    clean_displays+=("$display")
  done < <(worktree_rows)

  if [ "${#clean_paths[@]}" -eq 0 ]; then
    if [ "$merged_only" = 1 ]; then
      echo "No clean merged non-main worktrees found."
    else
      echo "No clean non-main worktrees found."
    fi
    print_clean_skips
    return 0
  fi

  if [ "$no_confirm" != 1 ]; then
    if [ "$merged_only" = 1 ]; then
      echo "Remove ${#clean_paths[@]} clean merged non-main worktree(s)?"
    else
      echo "Remove ${#clean_paths[@]} clean non-main worktree(s)?"
    fi
    printf '  %s\n' "${clean_displays[@]}"
    printf '[y/N] '
    if ! read -r reply; then
      reply=""
    fi
    case "$reply" in
      y|Y|yes|YES)
        ;;
      *)
        echo "Aborted."
        return 130
        ;;
    esac
  fi

  for i in "${!clean_paths[@]}"; do
    path=${clean_paths[$i]}
    display=${clean_displays[$i]}
    if git worktree remove "$path" >&2; then
      removed_displays+=("$display")
    else
      failed=1
      failed_displays+=("$display")
    fi
  done

  if [ "${#removed_displays[@]}" -gt 0 ]; then
    echo "Removed clean worktrees:"
    printf '  %s\n' "${removed_displays[@]}"
  fi
  print_clean_skips
  if [ "${#failed_displays[@]}" -gt 0 ]; then
    echo "Failed to remove worktrees:"
    printf '  %s\n' "${failed_displays[@]}"
  fi

  return "$failed"
}

list_candidates() {
  local root root_branch_name root_sha branch path row seen_branches sha
  local branch_row sorted_branch sort_value branch_sort_configured
  local -a worktree_rows branches branch_sort_values

  seen_branches=""
  branch_sort_configured=0

  root=$(find_worktrees_root) || {
    echo "Could not find .worktrees directory or Git repository root." >&2
    return 1
  }
  root=$(cd "$root" && pwd -P)

  cd "$root"
  root_branch_name=$(root_branch)
  root_sha=$(git rev-parse --short=7 HEAD 2>/dev/null || true)

  if [ -n "$root_branch_name" ]; then
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$root_branch_name" "$root" root root 0 "$root_sha"
    seen_branches="${seen_branches}${root_branch_name}"$'\n'
  fi

  while IFS= read -r row; do
    [ -n "$row" ] || continue
    worktree_rows+=("$row")
  done < <(worktree_branch_rows)

  while IFS= read -r sort_value; do
    [ -n "$sort_value" ] || continue
    branch_sort_values+=("$sort_value")
  done < <(git config --get-all branch.sort 2>/dev/null || true)

  if [ "${#branch_sort_values[@]}" -gt 0 ]; then
    branch_sort_configured=1
  fi

  while IFS= read -r row; do
    [ -n "$row" ] || continue
    branches+=("$row")
  done < <(branch_ref_rows "${branch_sort_values[@]}")

  if [ "$branch_sort_configured" = 1 ]; then
    for branch_row in "${branches[@]}"; do
      [ -n "$branch_row" ] || continue
      sorted_branch=${branch_row%%$'\t'*}
      [ -n "$sorted_branch" ] || continue

      for row in "${worktree_rows[@]}"; do
        [ -n "$row" ] || continue
        branch=${row%%$'\t'*}
        row=${row#*$'\t'}
        path=${row%%$'\t'*}
        sha=${row#*$'\t'}
        [ "$branch" = "$sorted_branch" ] || continue
        [ -n "$path" ] || break
        is_existing_worktree_path "$path" || break
        if ! list_contains "$branch" "$seen_branches"; then
          seen_branches="${seen_branches}${branch}"$'\n'
          printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$branch" "$path" worktree worktree 0 "$sha"
        fi
        break
      done
    done
  else
    for row in "${worktree_rows[@]}"; do
      [ -n "$row" ] || continue
      branch=${row%%$'\t'*}
      row=${row#*$'\t'}
      path=${row%%$'\t'*}
      sha=${row#*$'\t'}
      [ -n "$branch" ] || continue
      [ -n "$path" ] || continue
      is_existing_worktree_path "$path" || continue
      list_contains "$branch" "$seen_branches" && continue
      seen_branches="${seen_branches}${branch}"$'\n'
      printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$branch" "$path" worktree worktree 0 "$sha"
    done
  fi

  for row in "${branches[@]}"; do
    [ -n "$row" ] || continue
    branch=${row%%$'\t'*}
    sha=${row#*$'\t'}
    [ -n "$branch" ] || continue
    list_contains "$branch" "$seen_branches" && continue
    seen_branches="${seen_branches}${branch}"$'\n'
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$branch" "" branch branch 1 "$sha"
  done

  return 0
}

resolve_path() {
  local target="${1:-}"
  local root worktree_dir worktree_parent path

  if [ -z "$target" ]; then
    echo "Usage: wt __path <target>" >&2
    return 1
  fi

  root=$(find_worktrees_root) || {
    echo "Could not find .worktrees directory or Git repository root." >&2
    return 1
  }
  root=$(cd "$root" && pwd -P)

  cd "$root"

  if [ "$target" = "." ] || [ "$target" = "-" ]; then
    printf '%s\n' "$root"
    return 0
  fi

  worktree_dir="$root/.worktrees/$target"

  path=$(worktree_path_for_branch "$target")
  if [ -n "$path" ]; then
    printf '%s\n' "$path"
    return 0
  fi

  if git show-ref --verify --quiet "refs/heads/$target"; then
    echo "Creating worktree for branch '$target'..." >&2
    worktree_parent=$(dirname "$worktree_dir")
    mkdir -p "$worktree_parent"
    git worktree add "$worktree_dir" "$target" >&2
    printf '%s\n' "$worktree_dir"
    return 0
  fi

  echo "Branch '$target' does not exist" >&2
  return 1
}

format_rows() {
  awk -F '\t' '
    function display_path(path,    npath, nroot, path_parts, root_parts, common, i, out) {
      if (path == "") return ""
      if (root_path != "" && path == root_path) return "."
      if (root_path != "" && root_path != "/" && index(path, root_path "/") == 1) return substr(path, length(root_path) + 2)
      if (root_path == "/" && substr(path, 1, 1) == "/") return substr(path, 2)
      if (root_path != "" && substr(path, 1, 1) == "/" && substr(root_path, 1, 1) == "/") {
        npath = split(path, path_parts, "/")
        nroot = split(root_path, root_parts, "/")
        common = 1
        while (common <= npath && common <= nroot && path_parts[common] == root_parts[common]) common++
        out = ""
        for (i = common; i <= nroot; i++) if (root_parts[i] != "") out = out (out == "" ? "" : "/") ".."
        for (i = common; i <= npath; i++) if (path_parts[i] != "") out = out (out == "" ? "" : "/") path_parts[i]
        return out == "" ? "." : out
      }
      return path
    }
    {
      rows[NR] = $0
      if ($3 == "root") root_path = $2
    }
    END {
      for (i = 1; i <= NR; i++) {
        split(rows[i], f, "\t")
        shown_path[i] = display_path(f[2])
        sha_label[i] = f[6]
        branch_label[i] = f[1]
        if (length(sha_label[i]) > sha_width) sha_width = length(sha_label[i])
        if (length(branch_label[i]) > branch_width) branch_width = length(branch_label[i])
      }
      for (i = 1; i <= NR; i++) {
        if (shown_path[i] == "") {
          printf "%-" sha_width "s %s\n", sha_label[i], branch_label[i]
        } else {
          printf "%-" sha_width "s %-" branch_width "s %s\n", sha_label[i], branch_label[i], shown_path[i]
        }
      }
    }
  '
}

pick_candidate() {
  local rows selection branch

  rows=$(list_candidates)
  if [ -z "$rows" ]; then
    echo "No worktrees or local branches found." >&2
    return 1
  fi

  if command -v fzf >/dev/null 2>&1; then
    selection=$(printf '%s\n' "$rows" | format_rows | fzf --height=~50%) || return 130
    branch=$(printf '%s\n' "$selection" | awk '{ print $2 }')
    [ -n "$branch" ] || return 1
    resolve_path "$branch"
  else
    printf '%s\n' "$rows" | format_rows
  fi
}

print_zsh_completion() {
  cat <<'EOF'
#compdef wt

_wt() {
  local -a values labels option_values option_labels
  local -a active_values active_labels normal_values normal_labels
  local line branch worktree_path kind label sort sha formatted_label display_path root_path cur wt_rows branch_label
  local -a fields filtered_values filtered_labels
  local branch_width sha_width max_branch_width=0 max_sha_width=0 i

  _wt_fuzzy_match() {
    local needle="${1:l}" haystack="${2:l}" char
    local i

    [[ -n "$needle" ]] || return 0

    for ((i = 1; i <= ${#needle}; i++)); do
      char="${needle[i]}"
      if [[ "$haystack" == *"$char"* ]]; then
        haystack="${haystack#*"$char"}"
      else
        return 1
      fi
    done

    return 0
  }

  _wt_display_path() {
    local path="$1" root="$2" rel=""
    local -a path_parts root_parts
    local i j

    if [[ -z "$path" ]]; then
      print -r -- ""
      return
    fi
    if [[ -n "$root" && "$path" == "$root" ]]; then
      print -r -- "."
      return
    fi
    if [[ -n "$root" && "$root" != "/" && "$path" == "$root"/* ]]; then
      print -r -- "${path#$root/}"
      return
    fi
    if [[ "$root" == "/" && "$path" == /* ]]; then
      print -r -- "${path#/}"
      return
    fi
    if [[ -n "$root" && "$path" == /* && "$root" == /* ]]; then
      path_parts=("${(@s:/:)path}")
      root_parts=("${(@s:/:)root}")
      i=1
      while (( i <= ${#path_parts} && i <= ${#root_parts} )) && [[ "${path_parts[i]}" == "${root_parts[i]}" ]]; do
        (( i++ ))
      done
      for ((j = i; j <= ${#root_parts}; j++)); do
        [[ -n "${root_parts[j]}" ]] && rel="${rel:+$rel/}.."
      done
      for ((j = i; j <= ${#path_parts}; j++)); do
        [[ -n "${path_parts[j]}" ]] && rel="${rel:+$rel/}${path_parts[j]}"
      done
      print -r -- "${rel:-.}"
      return
    fi

    print -r -- "$path"
  }

  cur="${words[CURRENT]}"

  if [[ "$cur" == -* ]]; then
    option_values=(--latest --clean --merged -l -c -f -m -cf -fc -cm -mc -cfm)
    option_labels=(
      "--latest  switch to the latest local branch by committer date"
      "--clean   remove clean non-main worktrees after confirmation"
      "--merged  with -c/--clean, remove only worktrees merged into an optional rev"
      "-l        switch to the latest local branch by committer date"
      "-c        remove clean non-main worktrees after confirmation"
      "-f        skip confirmation when used with -c/--clean"
      "-m        with -c/--clean, shorthand for --merged"
      "-cf       remove clean non-main worktrees without confirmation"
      "-fc       remove clean non-main worktrees without confirmation"
      "-cm       remove clean merged non-main worktrees after confirmation"
      "-mc       remove clean merged non-main worktrees after confirmation"
      "-cfm      remove clean merged non-main worktrees without confirmation"
    )
    compadd -Q -V wt-options -d option_labels -l -- "${option_values[@]}"
    return
  fi

  wt_rows=$(command wt __list 2>/dev/null)

  while IFS= read -r line; do
    fields=("${(@ps:\t:)line}")
    branch="$fields[1]"
    worktree_path="$fields[2]"
    kind="$fields[3]"
    [[ -n "$branch" ]] || continue
    [[ "$kind" == "root" ]] && root_path="$worktree_path"
  done <<< "$wt_rows"

  while IFS= read -r line; do
    fields=("${(@ps:\t:)line}")
    branch="$fields[1]"
    worktree_path="$fields[2]"
    [[ -n "$branch" ]] || continue
    sha="$fields[6]"
    branch_label="$branch"
    sha_width=${#sha}
    branch_width=${#branch_label}
    (( sha_width > max_sha_width )) && max_sha_width=$sha_width
    (( branch_width > max_branch_width )) && max_branch_width=$branch_width
  done <<< "$wt_rows"

  while IFS= read -r line; do
    fields=("${(@ps:\t:)line}")
    branch="$fields[1]"
    worktree_path="$fields[2]"
    kind="$fields[3]"
    label="$fields[4]"
    sort="$fields[5]"
    sha="$fields[6]"
    [[ -n "$branch" ]] || continue

    display_path=$(_wt_display_path "$worktree_path" "$root_path")
    branch_label="$branch"

    if [[ -z "$display_path" ]]; then
      formatted_label=$(printf "%-${max_sha_width}s %s" "$sha" "$branch_label")
    else
      formatted_label=$(printf "%-${max_sha_width}s %-${max_branch_width}s %s" "$sha" "$branch_label" "$display_path")
    fi

    if [[ "$sort" == 0 ]]; then
      active_values+=("$branch")
      active_labels+=("$formatted_label")
    else
      normal_values+=("$branch")
      normal_labels+=("$formatted_label")
    fi
  done <<< "$wt_rows"

  values=("${active_values[@]}" "${normal_values[@]}")
  labels=("${active_labels[@]}" "${normal_labels[@]}")

  if [[ -n "$cur" ]]; then
    for ((i = 1; i <= ${#values}; i++)); do
      if _wt_fuzzy_match "$cur" "${values[i]}"; then
        filtered_values+=("${values[i]}")
        filtered_labels+=("${labels[i]}")
      fi
    done

    (( ${#filtered_values} > 0 )) && compadd -U -Q -V wt-branches -d filtered_labels -l -- "${filtered_values[@]}"
  else
    (( ${#values} > 0 )) && compadd -Q -V wt-branches -d labels -l -- "${values[@]}"
  fi
}

compdef _wt wt
EOF
}

case "${1:-}" in
  --help|-h)
    usage
    ;;
  --zsh-completion)
    print_zsh_completion
    ;;
  __list)
    list_candidates
    ;;
  __latest_branch)
    latest_branch
    ;;
  __path)
    shift
    resolve_path "${1:-}"
    ;;
  --latest|-l)
    shift
    if [ "$#" -ne 0 ]; then
      latest_usage_error
      exit $?
    fi
    resolve_latest_path
    ;;
  "")
    pick_candidate
    ;;
  *)
    if is_latest_mixed_short_option_token "${1:-}"; then
      latest_usage_error
      exit $?
    elif is_clean_option_token "${1:-}"; then
      clean_worktrees "$@"
    else
      resolve_path "$1"
    fi
    ;;
esac
