#!/usr/bin/env bash
set -eo pipefail

MERGED_BRANCHES=""
GONE_BRANCHES=""

usage() {
  cat <<'EOF'
Usage: wt
       wt --help
       wt --zsh-completion
       wt __list
       wt __path <branch>

With no arguments, wt opens an fzf picker when fzf is available.

wt is normally used through its zsh autoload function so it can change the
current shell directory. The executable provides shared data for completion and
Neovim integrations.
EOF
}

find_worktrees_root() {
  local dir="${1:-$PWD}"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/.worktrees" ]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir=$(dirname "$dir")
  done

  return 1
}

default_branch_base() {
  local base
  base=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)
  if [ -n "$base" ]; then
    printf '%s\n' "$base"
    return 0
  fi

  if git show-ref --verify --quiet refs/heads/main; then
    printf '%s\n' main
    return 0
  fi

  if git show-ref --verify --quiet refs/heads/master; then
    printf '%s\n' master
    return 0
  fi

  return 1
}

list_contains() {
  local needle="$1"
  local haystack="$2"

  [ -n "$haystack" ] || return 1
  printf '%s\n' "$haystack" | grep -Fxq -- "$needle"
}

branch_label() {
  local branch="$1"
  local local_default_branch="$2"
  local label=""

  if list_contains "$branch" "$GONE_BRANCHES"; then
    label="gone"
  fi

  if [ "$branch" != "$local_default_branch" ] && list_contains "$branch" "$MERGED_BRANCHES"; then
    if [ -n "$label" ]; then
      label="$label, merged"
    else
      label="merged"
    fi
  fi

  printf '%s\n' "$label"
}

list_candidates() {
  local root default_branch local_default_branch branch path label label_field sort kind row seen_branches
  local -a worktree_branches branches normal_rows merged_rows gone_rows

  seen_branches=""

  root=$(find_worktrees_root) || {
    echo "Could not find .worktrees directory in parent hierarchy." >&2
    return 1
  }

  cd "$root"

  while IFS= read -r branch; do
    [ -n "$branch" ] || continue
    worktree_branches+=("$branch")
  done < <(
    git worktree list --porcelain 2>/dev/null |
      awk '
        /^worktree / {
          path = substr($0, 10)
          marker = "/.worktrees/"
          idx = index(path, marker)
          if (idx > 0) print substr(path, idx + length(marker))
        }
      '
  )

  while IFS= read -r branch; do
    [ -n "$branch" ] || continue
    branches+=("$branch")
  done < <(git for-each-ref --format='%(refname:short)' refs/heads/ 2>/dev/null)

  default_branch=$(default_branch_base || true)
  local_default_branch=${default_branch#*/}

  MERGED_BRANCHES=""
  if [ -n "$default_branch" ]; then
    while IFS= read -r branch; do
      [ -n "$branch" ] || continue
      MERGED_BRANCHES="${MERGED_BRANCHES}${branch}"$'\n'
    done < <(git for-each-ref --merged="$default_branch" --format='%(refname:short)' refs/heads/ 2>/dev/null)
  fi

  GONE_BRANCHES=""
  while IFS='|' read -r branch track; do
    [ -n "$branch" ] || continue
    if [ "$track" = "[gone]" ]; then
      GONE_BRANCHES="${GONE_BRANCHES}${branch}"$'\n'
    fi
  done < <(git for-each-ref --format='%(refname:short)|%(upstream:track)' refs/heads/ 2>/dev/null)

  for branch in "${worktree_branches[@]}"; do
    [ -n "$branch" ] || continue
    list_contains "$branch" "$seen_branches" && continue
    seen_branches="${seen_branches}${branch}"$'\n'

    label="worktree"
    if list_contains "$branch" "$GONE_BRANCHES"; then
      label="$label, gone"
    fi
    if [ "$branch" != "$local_default_branch" ] && list_contains "$branch" "$MERGED_BRANCHES"; then
      label="$label, merged"
    fi

    path="$root/.worktrees/$branch"
    printf '%s\t%s\t%s\t%s\t%s\n' "$branch" "$path" worktree "$label" 0
  done

  for branch in "${branches[@]}"; do
    [ -n "$branch" ] || continue
    list_contains "$branch" "$seen_branches" && continue
    seen_branches="${seen_branches}${branch}"$'\n'

    label=$(branch_label "$branch" "$local_default_branch")
    kind="branch"
    sort=1
    if [ -n "$label" ]; then
      if list_contains "$branch" "$GONE_BRANCHES"; then
        sort=3
      else
        sort=2
      fi
    fi

    path="$root/.worktrees/$branch"
    label_field=${label:-'-'}
    row=$(printf '%s\t%s\t%s\t%s\t%s' "$branch" "$path" "$kind" "$label_field" "$sort")
    case "$sort" in
      2) merged_rows+=("$row") ;;
      3) gone_rows+=("$row") ;;
      *) normal_rows+=("$row") ;;
    esac
  done

  ((${#normal_rows[@]})) && printf '%s\n' "${normal_rows[@]}"
  ((${#merged_rows[@]})) && printf '%s\n' "${merged_rows[@]}"
  ((${#gone_rows[@]})) && printf '%s\n' "${gone_rows[@]}"
  return 0
}

resolve_path() {
  local target="${1:-}"
  local root worktree_dir worktree_parent

  if [ -z "$target" ]; then
    echo "Usage: wt __path <branch>" >&2
    return 1
  fi

  root=$(find_worktrees_root) || {
    echo "Could not find .worktrees directory in parent hierarchy." >&2
    return 1
  }

  cd "$root"
  worktree_dir="$root/.worktrees/$target"

  if [ -d "$worktree_dir" ]; then
    printf '%s\n' "$worktree_dir"
    return 0
  fi

  if git show-ref --verify --quiet "refs/heads/$target"; then
    echo "Creating worktree for branch '$target'..." >&2
    worktree_parent=$(dirname "$worktree_dir")
    mkdir -p "$worktree_parent"
    git worktree add "$worktree_dir" "$target" >&2
    printf '%s\n' "$worktree_dir"
    return 0
  fi

  echo "Branch '$target' does not exist" >&2
  return 1
}

format_rows() {
  awk -F '\t' '
    {
      if (length($1) > w1) w1 = length($1)
      rows[NR] = $0
    }
    END {
      for (i = 1; i <= NR; i++) {
        split(rows[i], f, "\t")
        label = f[4]
        if (label == "-") label = ""
        printf "%-" w1 "s", f[1]
        if (label != "") printf "  [%s]", label
        printf "\n"
      }
    }
  '
}

pick_candidate() {
  local rows selection branch

  rows=$(list_candidates)
  if [ -z "$rows" ]; then
    echo "No worktrees or local branches found." >&2
    return 1
  fi

  if command -v fzf >/dev/null 2>&1; then
    selection=$(printf '%s\n' "$rows" | format_rows | fzf --height=~50%) || return 130
    branch=$(printf '%s\n' "$selection" | awk '{ print $1 }')
    [ -n "$branch" ] || return 1
    resolve_path "$branch"
  else
    printf '%s\n' "$rows" | format_rows
  fi
}

print_zsh_completion() {
  cat <<'EOF'
#compdef wt

_wt() {
  local -a values labels
  local -a active_values active_labels normal_values normal_labels merged_values merged_labels gone_values gone_labels
  local branch worktree_path kind label sort formatted_label
  local branch_width max_width=0

  while IFS=$'\t' read -r branch worktree_path kind label sort; do
    [[ -n "$branch" ]] || continue
    branch_width=${#branch}
    (( branch_width > max_width )) && max_width=$branch_width
  done < <(command wt __list 2>/dev/null)

  while IFS=$'\t' read -r branch worktree_path kind label sort; do
    [[ -n "$branch" ]] || continue

    [[ "$label" == "-" ]] && label=""
    if [[ -n "$label" ]]; then
      formatted_label=$(printf "%-${max_width}s  [%s]" "$branch" "$label")
    else
      formatted_label="$branch"
    fi

    case "$sort" in
      0)
        active_values+=("$branch")
        active_labels+=("$formatted_label")
        ;;
      2)
        merged_values+=("$branch")
        merged_labels+=("$formatted_label")
        ;;
      3)
        gone_values+=("$branch")
        gone_labels+=("$formatted_label")
        ;;
      *)
        normal_values+=("$branch")
        normal_labels+=("$formatted_label")
        ;;
    esac
  done < <(command wt __list 2>/dev/null)

  values=("${active_values[@]}" "${normal_values[@]}" "${merged_values[@]}" "${gone_values[@]}")
  labels=("${active_labels[@]}" "${normal_labels[@]}" "${merged_labels[@]}" "${gone_labels[@]}")

  (( ${#values} > 0 )) && compadd -Q -V wt-branches -d labels -- "${values[@]}"
}

compdef _wt wt
EOF
}

case "${1:-}" in
  --help|-h)
    usage
    ;;
  --zsh-completion)
    print_zsh_completion
    ;;
  __list)
    list_candidates
    ;;
  __path)
    shift
    resolve_path "${1:-}"
    ;;
  "")
    pick_candidate
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
