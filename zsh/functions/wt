emulate -L zsh

local target="${1:-}"
local target_path

if [[ -z "$target" ]]; then
  if ! command -v fzf >/dev/null 2>&1; then
    command wt
    return $?
  fi

  target_path=$(command wt) || return $?
  if [[ -z "$target_path" ]]; then
    return 0
  fi
  cd "$target_path" || return 1
  pwd
  return 0
fi

target_path=$(command wt __path "$target") || return 1
cd "$target_path" || return 1
pwd
